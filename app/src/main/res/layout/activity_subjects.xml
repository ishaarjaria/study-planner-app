<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7">

    <!-- 🔽 SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomFixed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE -->
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="My Subjects"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Manage your study subjects"
                android:textColor="#777"
                android:layout_marginBottom="16dp"/>

            <!-- STATS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="@drawable/card_blue"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:text="5\nSubjects"
                    android:gravity="center"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:text="73%\nAvg Progress"
                    android:gravity="center"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:text="79h\nTotal Hours"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- SECTION -->
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="All Subjects"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- SUBJECT 1 -->
            <LinearLayout
                android:id="@+id/subjectsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_purple"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Mathematics"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:background="@drawable/card_pink"
                    android:text="Hard"
                    android:textSize="12sp"/>

                <!-- Progress bar -->
                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="85"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Next Topic: Calculus Integration"
                    android:textSize="12sp"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Study Time: 24h"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- SUBJECT 2 -->
            <LinearLayout
                android:id="@+id/subjectsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_blue"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Physics"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:background="@drawable/card_yellow"
                    android:text="Medium"
                    android:textSize="12sp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="70"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Next Topic: Electromagnetism"
                    android:textSize="12sp"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Study Time: 18h"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- SUBJECT 3 -->
            <LinearLayout
                android:id="@+id/subjectsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_green"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Chemistry"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:background="@drawable/card_yellow"
                    android:text="Medium"
                    android:textSize="12sp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="65"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Next Topic: Organic Chemistry"
                    android:textSize="12sp"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Study Time: 15h"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- SUBJECT 4 -->
            <LinearLayout
                android:id="@+id/subjectsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_pink"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="English"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:background="@drawable/card_green"
                    android:text="Easy"
                    android:textSize="12sp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="80"
                    android:layout_marginTop="6dp"/>

                <TextView android:layout_height="wrap_content"
                    android:layout_width="wrap_content" android:text="Next Topic: Poetry Analysis" android:textSize="12sp"/>
                <TextView android:layout_height="wrap_content"
                    android:layout_width="wrap_content" android:text="Study Time: 12h" android:textSize="12sp"/>
            </LinearLayout>

            <!-- SUBJECT 5 -->
            <LinearLayout
                android:id="@+id/subjectsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_red"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView android:layout_height="wrap_content"
                    android:layout_width="wrap_content" android:text="History" android:textStyle="bold"/>
                <TextView android:layout_height="wrap_content"
                    android:layout_width="wrap_content" android:background="@drawable/card_green" android:text="Easy" android:textSize="12sp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="55"
                    android:layout_marginTop="6dp"/>

                <TextView android:layout_height="wrap_content"
                    android:layout_width="wrap_content" android:text="Next Topic: Cold War Era" android:textSize="12sp"/>
                <TextView android:layout_height="wrap_content"
                    android:layout_width="wrap_content" android:text="Study Time: 10h" android:textSize="12sp"/>
            </LinearLayout>

            <!-- ADD BUTTON -->
            <Button
                android:id="@+id/btnAddSubject"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="+ Add New Subject"
                android:textAllCaps="false"
                android:background="@drawable/card_purple"/>

        </LinearLayout>
    </ScrollView>

    <!-- 🔽 FIXED FOOTER -->
    <LinearLayout
        android:id="@+id/bottomFixed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="← Back to Screen Navigator"
            android:gravity="center"
            android:background="#D6D4F5"
            android:layout_width="match_parent"
            android:layout_height="45dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:weightSum="5">

                <!-- Dashboard -->
                <LinearLayout
                    android:id="@+id/navDashboard"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/homebttn"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Calendar -->
                <LinearLayout
                    android:id="@+id/navCalendar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/calbutton"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calendar"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Tasks -->
                <LinearLayout
                    android:id="@+id/navTasks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/taskbutton"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tasks"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Progress -->
                <LinearLayout
                    android:id="@+id/navProgress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/chckbttn"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Progress"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Profile -->
                <LinearLayout
                    android:id="@+id/navProfile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/prflbttn"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>