<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Setup Your Profile"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="#222222"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 2/4"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- PROGRESS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#CBB8FF"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="#CBB8FF"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="#DDDDDD"/>

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="#DDDDDD"/>
        </LinearLayout>

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_gradient"
            android:layout_marginTop="34dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="40sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Your Exam Date"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="#2F2F2F"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="When is your next important exam"
                android:textSize="14sp"
                android:textColor="#777777"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main Exam Date"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#444444"
            android:layout_marginTop="30dp"/>

        <!-- DATE INPUT -->
        <EditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="dd-mm-yyyy"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_white"/>

        <!-- SPACE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- BACK -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="‹   Back"
                android:textAllCaps="false"
                android:textColor="#444444"
                android:textStyle="bold"
                android:background="@drawable/bg_button_outline"/>

            <!-- NEXT -->
            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Next   ›"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#4B3B77"
                android:layout_marginStart="12dp"
                android:background="@drawable/card_purple"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>