<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7"
    android:fitsSystemWindows="true"
    android:paddingTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Icon -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_logo"
            android:padding="12dp"/>

        <!-- Title -->
        <TextView
            android:text="Screen Navigator"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Subtitle -->
        <TextView
            android:text="AI Smart Study Planner\nClick any screen below to view"
            android:textSize="14sp"
            android:textColor="#777"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- BUTTONS -->

        <Button android:id="@+id/btn1" android:text="1. Dashboard"
            android:background="@drawable/bg1" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn2" android:text="2. AI Timetable Generator"
            android:background="@drawable/bg2" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn3" android:text="3. Calendar"
            android:background="@drawable/bg3" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn4" android:text="4. Tasks"
            android:background="@drawable/bg4" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn5" android:text="5. Study Timer"
            android:background="@drawable/bg5" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn6" android:text="6. Exam Countdown"
            android:background="@drawable/bg6" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn7" android:text="7. Reminders"
            android:background="@drawable/bg7" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn8" android:text="8. Progress Tracker"
            android:background="@drawable/bg8" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn9" android:text="9. Quick Notes"
            android:background="@drawable/bg9" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn10" android:text="10. Subjects"
            android:background="@drawable/bg10" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn11" android:text="11. AI Suggestions"
            android:background="@drawable/bg11" app:backgroundTint="@null" style="@style/btnStyle"/>

        <Button android:id="@+id/btn12" android:text="12. Profile"
            android:background="@drawable/bg12" app:backgroundTint="@null" style="@style/btnStyle"/>

    </LinearLayout>
</ScrollView>